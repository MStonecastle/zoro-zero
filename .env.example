# =============================================================================
# Zoro-Zero: Turnkey Local Agent Stack Environment Configuration Template
# Licensed under the MIT License (https://opensource.org/license/mit)
# Team-404, Michelle Stonecastle-20260527: v1.0.0
#
# DESCRIPTION:
#   Bootstrap template for setting up local variables (tokens, paths, and user ACLs)
#   for the containerized gateway handlers (Telegram/Discord).
#
# NOTES:
#   - Copy this file to '.env' before booting the container stack.
#   - Never commit '.env' (with real credentials) to remote repositories.
# =============================================================================

# -----------------------------------------------------------------------------
# Local Inference Routing (Zero-Trust Container DNS)
# -----------------------------------------------------------------------------
# Inside the virtual zoro-network, Ollama resolves to its service container name.
OLLAMA_HOST=http://ollama:11434

# Target Model (Qwen 3 8B Custom Context)
# Quantization: Q4_K_M (Fits fully inside 16 GB VRAM with 64K context window)
MODEL=qwen3:8b-64k

# -----------------------------------------------------------------------------
# CLI Mode Configurations
# -----------------------------------------------------------------------------
TERMINAL_TIMEOUT=180
TERMINAL_LIFETIME_SECONDS=300

# -----------------------------------------------------------------------------
# Telegram Gateway Scaffolding
# -----------------------------------------------------------------------------
# Bot token acquired via Telegram's @BotFather
#TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated Telegram User IDs allowed to execute terminal commands
#TELEGRAM_ALLOWED_USERS=your_telegram_user_id_here
#TELEGRAM_HOME_CHANNEL=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# Discord Gateway Scaffolding
# -----------------------------------------------------------------------------
# Bot token acquired via Discord Developer Portal
#DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Comma-separated Discord User IDs allowed to execute terminal commands
#DISCORD_ALLOWED_USERS=your_discord_user_id_here
